		"@types/jsdom": "^28.0.1",
		"@types/node": "^25.5.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.1",
